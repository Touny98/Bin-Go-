# ==========================================
# BinGo! MVP Production Configuration Template
# ==========================================

# Service Ports
PORT=3000
NODE_ENV=production

# Database Configuration (Docker Compose context)
DATABASE_URL=postgres://bingo_user:bingo_password@postgres:5432/bingo_db
POSTGRES_USER=bingo_user
POSTGRES_PASSWORD=bingo_secure_password_replace_me
POSTGRES_DB=bingo_db

# Redis Cache & Queues (Docker Compose context)
REDIS_URL=redis://redis:6379

# Admin Console Security (Basic Auth for monitor / queues)
ADMIN_PASSWORD=super_secure_operator_password_replace_me

# MercadoPago Gateway Credentials (Real integration)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxx-xxxxxx-xxxxxx
MERCADOPAGO_WEBHOOK_SECRET=your_mercadopago_webhook_signature_secret

# WhatsApp Business / Web Provider Configurations
WHATSAPP_NUMBER=+5491100000000
# Set sandbox parameter if using WhatsApp sandbox mode
WHATSAPP_SANDBOX_ACTIVE=false

# PostHog Analytics Engine
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
