# ─── ngrok (para exposicion local) ──────────────────────────
# Obtener en: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN="tu_ngrok_authtoken"
# Dominio estatico gratuito (crear en: https://dashboard.ngrok.com/domains)
# Ejemplo: bingo-tunombre.ngrok-free.app
NGROK_DOMAIN=""

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Base de datos ────────────────────────────────────────────
DATABASE_URL="postgres://bingo_user:bingo_password@postgres:5432/bingo_db"
POSTGRES_USER=bingo_user
POSTGRES_PASSWORD=bingo_password
POSTGRES_DB=bingo_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── Admin ───────────────────────────────────────────────────
# Genera un valor seguro con: openssl rand -hex 32
ADMIN_JWT_SECRET="cambia-esto-por-un-secreto-seguro"
ADMIN_DEFAULT_PASSWORD="BinGo!Admin2024"
ADMIN_PASSWORD="bingoadmin"

# ─── WhatsApp ────────────────────────────────────────────────
# Para modo QR (whatsapp-web.js): dejar WHATSAPP_MOCK=false
# Para testing local sin teléfono: WHATSAPP_MOCK=true
WHATSAPP_MOCK=false
WA_TOKEN="tu_token_meta_cloud_api"
WA_PHONE_NUMBER_ID="tu_phone_number_id"
WA_VERIFY_TOKEN="tu_verify_token_seguro"

# ─── MercadoPago ─────────────────────────────────────────────
MP_ACCESS_TOKEN="tu_mp_access_token_produccion"
# Reemplaza con tu dominio real
MP_BACK_URL_SUCCESS="https://tu-dominio.com/success"
MP_BACK_URL_PENDING="https://tu-dominio.com/pending"
MP_BACK_URL_FAILURE="https://tu-dominio.com/failure"
MP_WEBHOOK_URL="https://tu-dominio.com/api/payments/webhook"
